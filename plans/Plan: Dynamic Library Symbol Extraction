export interface LibraryParam {                                                                                                                                                                                                                                                                        │
  name: string;                                                                                                                                                                                                                                                                                        │
  type: string;                                                                                                                                                                                                                                                                                        │
  direction: 'input' | 'output' | 'inOut';                                                                                                                                                                                                                                                             │
  comment?: string;                                                                                                                                                                                                                                                                                    │
}                                                                                                                                                                                                                                                                                                      │
                                                                                                                                                                                                                                                                                                       │
export interface LibrarySymbol {                                                                                                                                                                                                                                                                       │
  name: string;                                                                                                                                                                                                                                                                                        │
  kind: 'functionBlock' | 'function' | 'interface' | 'struct' | 'type';                                                                                                                                                                                                                                │
  namespace: string;          // library name (e.g. "mobject-core")                                                                                                                                                                                                                                    │
  extends?: string;                                                                                                                                                                                                                                                                                    │
  implements?: string[];                                                                                                                                                                                                                                                                               │
  inputs?: LibraryParam[];    // undefined = not available (compiled)                                                                                                                                                                                                                                  │
  outputs?: LibraryParam[];                                                                                                                                                                                                                                                                            │
  inOuts?: LibraryParam[];                                                                                                                                                                                                                                                                             │
  returnType?: string;        // for functions                                                                                                                                                                                                                                                         │
}                                                                                                                                                                                                                                                                                                      │
                                                                                                                                                                                                                                                                                                       │
export interface LibraryIndex {                                                                                                                                                                                                                                                                        │
  name: string;               // library name                                                                                                                                                                                                                                                          │
  symbols: LibrarySymbol[];                                                                                                                                                                                                                                                                            │
  hasSignatures: boolean;     // true only for source .library files                                                                                                                                                                                                                                   │
}                                                                                                                                                                                                                                                                                                      │
                                                                                                                                                                                                                                                                                                       │
Add readLibraryIndex(filePath: string): LibraryIndex:                                                                                                                                                                                                                                                  │
                                                                                                                                                                                                                                                                                                       │
- Compiled libraries: same string-table scan as readLibraryTypeNames, returns symbols with kind='functionBlock'/'function'/etc., no params, hasSignatures=false.                                                                                                                                       │
- Source libraries (.library): additionally parse ST declarations from raw ASCII scan:                                                                                                                                                                                                                 │
  a. Decompress string table, scan for printable ASCII sequences ≥ 10 chars                                                                                                                                                                                                                            │
  b. Find sequences starting with FUNCTION_BLOCK, INTERFACE, FUNCTION, TYPE                                                                                                                                                                                                                            │
  c. For each FB declaration chunk, extract:                                                                                                                                                                                                                                                           │
      - Name, EXTENDS, IMPLEMENTS from the header line                                                                                                                                                                                                                                                 │
    - VAR_INPUT / VAR_OUTPUT / VAR_IN_OUT blocks → LibraryParam[]                                                                                                                                                                                                                                      │
    - Line format:   name : TYPE; or   name : TYPE; // comment                                                                                                                                                                                                                                         │
  d. For standalone functions: extract FUNCTION name : RETURNTYPE + VAR_INPUT block                                                                                                                                                                                                                    │
  - hasSignatures=true                                                                                                                                                                                                                                                                                 │
                                                                                                                                                                                                                                                                                                       │
Keep readLibraryTypeNames as a thin wrapper over readLibraryIndex for backward compatibility (no callers need updating yet).                                                                                                                                                                           │
                                                                                                                                                                                                                                                                                                       │
ST declaration parsing strategy (source libraries)                                                                                                                                                                                                                                                     │
                                                                                                                                                                                                                                                                                                       │
The string table stores each FB/method as a contiguous raw text block separated by binary bytes. Scan for ASCII runs ≥ 10 chars; a run starting with FUNCTION_BLOCK contains the complete header + VAR block. Parse with simple line-by-line logic:                                                    │
                                                                                                                                                                                                                                                                                                       │
state machine: IDLE → IN_FB_DECL → IN_VAR_INPUT | IN_VAR_OUTPUT | IN_VAR_IN_OUT → IN_FB_BODY                                                                                                                                                                                                           │
                                                                                                                                                                                                                                                                                                       │
