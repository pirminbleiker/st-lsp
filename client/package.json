{
  "name": "st-lsp-client",
  "private": true,
  "version": "1.7.2",
  "description": "VS Code extension for IEC 61131-3 Structured Text",
  "publisher": "pirminbleiker",
  "repository": {
    "type": "git",
    "url": "https://github.com/pirminbleiker/st-lsp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:iec-st"
  ],
  "main": "out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "iec-st",
        "aliases": [
          "Structured Text",
          "iec-st"
        ],
        "extensions": [
          ".st",
          ".ST",
          ".TcPOU",
          ".TcGVL",
          ".TcDUT",
          ".TcIO"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "iec-st",
        "scopeName": "source.iec-st",
        "path": "./syntaxes/iec-st.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "xmlMarkup",
        "superType": "comment",
        "description": "XML wrapper markup in TwinCAT source files"
      }
    ],
    "configuration": {
      "title": "Structured Text LSP",
      "properties": {
        "st-lsp.twincat.installPath": {
          "type": "string",
          "default": "",
          "description": "Path to the TwinCAT installation directory (e.g. C:\\TwinCAT\\3.1). When set, library references from .plcproj files are resolved from the Managed Libraries folder."
        }
      }
    },
    "configurationDefaults": {
      "[iec-st]": {
        "editor.foldingImportsByDefault": true,
        "editor.semanticTokenColorCustomizations": {
          "rules": {
            "xmlMarkup": "#404040"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --platform=node --format=cjs --external:vscode",
    "watch": "tsc -p tsconfig.json --watch",
    "test:integration": "vscode-test",
    "vscode:prepublish": "npm run bundle",
    "package": "npm run bundle && node scripts/copy-server.js && npx vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
