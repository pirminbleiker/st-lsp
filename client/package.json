{
  "name": "st-lsp-client",
  "private": true,
  "version": "0.0.1",
  "description": "VS Code extension for IEC 61131-3 Structured Text",
  "publisher": "pirminbleiker",
  "repository": {
    "type": "git",
    "url": "https://github.com/pirminbleiker/st-lsp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:iec-st"
  ],
  "main": "out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "iec-st",
        "aliases": [
          "Structured Text",
          "iec-st"
        ],
        "extensions": [
          ".st",
          ".ST",
          ".TcPOU",
          ".TcGVL",
          ".TcDUT",
          ".TcIO"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --platform=node --format=cjs --external:vscode",
    "watch": "tsc -p tsconfig.json --watch",
    "vscode:prepublish": "npm run bundle",
    "package": "npm run bundle && node scripts/copy-server.js && npx vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
