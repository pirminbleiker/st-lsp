{
  "name": "st-lsp-server",
  "private": true,
  "version": "0.0.1",
  "description": "IEC 61131-3 Structured Text LSP server",
  "main": "out/server.js",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "bundle": "esbuild src/server.ts --bundle --outfile=bundle/server.js --platform=node --format=cjs",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
